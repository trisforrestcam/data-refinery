# App
NODE_ENV=development
PORT=5001

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MongoDB
MONGODB_URI=mongodb://localhost:27017/datarefinery

# Elasticsearch APM (legacy, kept for compatibility)
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_APM_INDEX=traces-apm-*

# Elasticsearch Tracking
TRACKING_ES_INDEX=tracking-events-*
TRACKING_ES_TIMEOUT_MS=10000

# Overlay metrics scheduler target
# Required for the built-in scheduler. For multiple live matches, enqueue jobs dynamically.
OVERLAY_METRICS_TENANT_ID=tenant-001
OVERLAY_METRICS_MATCH_ID=000000000000000000000000
OVERLAY_METRICS_TIMELINE_IDS=timeline-001,timeline-002

# Internal API Key (server-to-server auth)
INTERNAL_API_KEY=change-me-in-production

# App context
ELASTIC_APM_ENVIRONMENT=development
TZ=Asia/Ho_Chi_Minh
